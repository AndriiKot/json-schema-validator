{
  "name": "json-schema-validator",
  "version": "0.4.0",
  "description": "Lightweight JSON Schema validator for Node.js and modern JavaScript environments",
  "main": "./lib/index.js",
  "exports": {
    ".": {
      "import": "./lib/index.js",
      "default": "./lib/index.js"
    }
  },
  "files": [
    "lib",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepare": "node tools/setGitHooks.js",
    "lint": "prettier -c \"**/*.js\" && eslint .",
    "fix": "prettier --write \"**/*.js\" && eslint . --fix",
    "test": "node --test",
    "prepublishOnly": "npm run lint && npm test",
    "bench": "node benchmarks/internal/native-vs-compiled.bench.mjs",
    "bench:dataset": "node benchmarks/internal/dataset-size.bench.mjs",
    "bench:compile": "node benchmarks/internal/compile-cost.bench.mjs",
    "bench:compare": "node benchmarks/compare/ajv.bench.mjs"
  },
  "imports": {
    "#lib": "./lib/index.js",
    "#tools": "./tools/index.js",
    "#benchmarks": "./benchmarks/index.mjs"
  },
  "keywords": [
    "json",
    "json-schema",
    "validator",
    "schema-validation",
    "validation",
    "json-validator"
  ],
  "author": "Andrii Kotsiuba",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AndriiKot/json-schema-validator.git"
  },
  "bugs": {
    "url": "https://github.com/AndriiKot/json-schema-validator/issues"
  },
  "homepage": "https://github.com/AndriiKot/json-schema-validator#readme",
  "engines": {
    "node": ">=18"
  },
  "private": false,
  "devDependencies": {
    "ajv": "^8.18.0",
    "eslint": "^9.39.2",
    "eslint-config-metarhia": "^9.1.5",
    "prettier": "^3.8.1",
    "tinybench": "^6.0.0"
  }
}
